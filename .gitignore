# ============================================================
# Michi project — .gitignore
# Stack: ASP.NET Core (backend) + Vite/React/TS (frontend)
# ============================================================

# ===== OS =====
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*.lnk

# ===== Editors / IDE =====
.vs/
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.swp
*.swo
*~
*.user
*.suo
*.userprefs
.codex/

# ============================================================
# Node / Vite / React (frontend)
# ============================================================
**/node_modules/
**/.npm/
**/.pnp.*
**/.yarn/cache
**/.yarn/install-state.gz

# Build output
**/dist/
**/build/
**/out/
**/.next/
**/.turbo/

# Vite cache
**/.vite/
**/.vite-cache/

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# Test / coverage
**/coverage/
**/.nyc_output/
**/playwright-report/
**/test-results/

# Local env (DO NOT commit secrets)
**/.env
**/.env.*.local
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
# Keep examples
!**/.env.example

# TypeScript incremental
**/*.tsbuildinfo

# ============================================================
# .NET / ASP.NET Core (backend)
# ============================================================

# Build outputs
**/bin/
**/obj/
**/out/
**/publish/
**/Debug/
**/Release/

# NuGet
**/*.nupkg
**/*.snupkg
**/.nuget/
**/packages/
!**/packages/build/
**/project.lock.json
**/project.fragment.lock.json
**/artifacts/

# EF Core / Entity Framework
**/Migrations/*.Designer.cs.bak

# ASP.NET / IIS
**/PublishProfiles/
**/*.pubxml
**/*.pubxml.user
**/*.publishproj
**/*_i.c
**/*_p.c
**/*_h.h
**/*.ilk
**/*.meta
**/*.obj
**/*.iobj
**/*.pch
**/*.pdb
**/*.ipdb
**/*.pgc
**/*.pgd
**/*.rsp
**/*.sbr
**/*.tlb
**/*.tli
**/*.tlh
**/*.tmp
**/*.tmp_proj
**/*_wpftmp.csproj
**/*.vspscc
**/*.vssscc
**/.builds
**/*.dbmdl
**/*.dbproj.schemaview
**/*.jfm
**/*.pfx
**/*.publishsettings
**/orleans.codegen.cs

# Visual Studio cache / options
**/.vs/
**/*.cachefile
**/*.sln.docstates

# JetBrains Rider
**/.idea/
**/*.sln.iml

# Test results
**/TestResults/
**/[Tt]est[Rr]esult*/
**/[Bb]uild[Ll]og.*

# Profiling
**/*.psess
**/*.vsp
**/*.vspx
**/*.sap

# ============================================================
# Database / data files
# ============================================================
**/*.mdf
**/*.ldf
**/*.ndf
**/App_Data/

# ============================================================
# Secrets / credentials (DO NOT commit)
# ============================================================
**/secrets.json
**/appsettings.*.local.json
**/appsettings.Production.json

# ============================================================
# Misc
# ============================================================
**/*.bak
**/*.tmp
**/Temp/
**/.DS_Store
